# ===========================================
# SciTaste environment template
# Copy this file to .env before your first run.
# ===========================================

# ===========================================
# Feishu / Lark app credentials
# Required for webhook verification and routing
# ===========================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_BOT_NAME=SciTaste Bot

# Optional fallback reply target when chat_id is unavailable
FEISHU_USER_ID=

# Optional explicit lark-cli path if it is not in PATH
FEISHU_CLI_CMD=

# `user` is the current default used by the repo
FEISHU_IM_IDENTITY=user

# ===========================================
# Webhook / tunnel
# ===========================================
NGROK_AUTHTOKEN=
NGROK_PATH=

# ===========================================
# Database / logging
# ===========================================
DATABASE_PATH=./data/scitaste.db
LOG_LEVEL=INFO

# ===========================================
# Embedding configuration
# valid values:
#   hash     - no model or API required, weakest semantics
#   local    - use a local embedding model under ./models
#   hf_api   - use Hugging Face Inference API
#   openai   - use OpenAI embedding API
# ===========================================
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSIONS=768

# Local embedding model
LOCAL_EMBEDDING_MODEL_PATH=./models/Qwen3-Embedding-8B
LOCAL_EMBEDDING_MODEL=
LOCAL_EMBEDDING_TRUST_REMOTE_CODE=true

# Hugging Face Inference API embedding
HF_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
HF_INFERENCE_PROVIDER=auto
HF_API_TIMEOUT=60
HF_TOKEN=
HF_API_KEY=

# OpenAI embedding API
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# ===========================================
# LLM parser configuration
# valid values:
#   auto     - local first if LOCAL_LLM_MODEL_PATH exists, otherwise OpenAI if key exists
#   local    - force local instruct/chat model
#   openai   - force OpenAI API
#   disabled - disable LLM parser fallback
# ===========================================
LLM_PARSER_PROVIDER=auto
LOCAL_LLM_MODEL_PATH=./models/Qwen3-4B-Instruct-2507
LOCAL_LLM_TRUST_REMOTE_CODE=true
LOCAL_LLM_DEVICE=auto
LLM_PARSER_OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Paper source credentials
# ===========================================
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=
OPENREVIEW_TOKEN=
IEEE_API_KEY=

# ===========================================
# Optional cold-start baseline PDF
# If set, cold start can merge this PDF with user input
# ===========================================
SCITASTE_BASELINE_PDF=

# ===========================================
# Feature flags / parser tuning
# ===========================================
SCITASTE_ALLOW_MOCK_PAPERS=false
PDF_PARSER_MIN_EMBED_SIMILARITY=0.30
